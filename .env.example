# === EMBEDDING CONFIG ===
# Provider auto-detected: OpenAI (api.openai.com), Gemini (AIza key), Ollama (localhost:11434)
EMBEDDER_BASE_URL="https://api.openai.com/v1"
EMBEDDER_API_KEY="your-api-key-here"
EMBEDDER_MODEL="text-embedding-3-small"
EMBEDDER_DIMENSION=1536

# === QDRANT CONFIG ===
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION_NAME="universal_rag_collection"

# === LLM CHAT CONFIG ===
# Provider auto-detected: OpenAI (api.openai.com), Gemini (AIza key), Ollama (localhost:11434)
LLM_BASE_URL="https://api.openai.com/v1"
LLM_API_KEY="your-api-key-here"
LLM_MODEL="gpt-3.5-turbo"

# === MEMORY & SEARCH CONFIG ===
MEMORY_TYPE="buffer_window"
MEMORY_SESSION_ID="default_session"
MEMORY_WINDOW_SIZE=5

SEARCH_SCORE_THRESHOLD=0.7
MAX_SEARCH_RESULTS=4
EMBEDDING_BATCH_SIZE=100
MAX_BATCH_SCANNER_RETRIES=3
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36"