# ============================================================
# Universal RAG - Environment Template
# Copy file ini menjadi `.env` lalu sesuaikan nilainya.
# ============================================================

# === LOGGING ===
# Pilihan: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL="INFO"

# === EMBEDDING CONFIG ===
# Dipakai saat ingest (membuat vector dokumen) dan retrieval dense query.
# Provider auto-detect:
# - OpenAI: base URL berisi api.openai.com
# - Gemini: API key diawali AIza
# - Ollama: base URL localhost:11434 atau berisi "ollama"
# Jika docker-compose memakai network_mode: "host", gunakan localhost.
EMBEDDER_BASE_URL="http://localhost:11434"
EMBEDDER_API_KEY=""
EMBEDDER_MODEL="nomic-embed-text:latest"
# HARUS sama dengan dimensi model embedding yang dipakai.
# Contoh:
# - text-embedding-3-small -> 1536
# - nomic-embed-text:latest -> 768
EMBEDDER_DIMENSION=768

# === QDRANT CONFIG ===
# Local dev: http://localhost:6333
# Docker internal network (dari container bot): http://qdrant:6333
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION_NAME="universal_rag_collection"

# === LLM CHAT CONFIG ===
# Dipakai saat generate jawaban dari konteks retrieval.
LLM_BASE_URL="http://localhost:11434"
LLM_API_KEY=""
LLM_MODEL="llama3"

# === MEMORY CONFIG ===
MEMORY_TYPE="buffer_window"
MEMORY_SESSION_ID="default_session"
# Jumlah pasangan chat (user+assistant) yang disimpan di memory window.
MEMORY_WINDOW_SIZE=5

# === RETRIEVAL TUNING ===
# Nilai minimum relevansi dokumen (0.0-1.0, lebih tinggi = lebih ketat).
SEARCH_SCORE_THRESHOLD=0.7
# Jumlah context documents maksimum yang dikirim ke prompt.
MAX_SEARCH_RESULTS=4

# === INGESTION TUNING ===
# Jumlah point per batch saat upsert ke Qdrant.
EMBEDDING_BATCH_SIZE=100
# Retry maksimum untuk batch scanner.
MAX_BATCH_SCANNER_RETRIES=3

# === SEARCH MODE (FASE 3) ===
# "dense"  = semantic similarity only
# "hybrid" = dense + sparse BM25 (perlu sparse vectors di collection)
SEARCH_MODE="dense"

# === RERANKER (FASE 3) ===
# Jika true, hasil retrieval akan diurutkan ulang oleh cross-encoder.
RERANKER_ENABLED=false
RERANKER_MODEL="Xenova/ms-marco-MiniLM-L-6-v2"

# === WEB SCRAPER ===
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36"

# === TELEGRAM BOT ===
# Dapatkan token dari @BotFather. Jangan commit token asli ke git.
TELEGRAM_BOT_TOKEN=""
# Opsional: whitelist user id Telegram, pisahkan dengan koma.
# Kosongkan untuk menonaktifkan whitelist.
TELEGRAM_ALLOWED_USERS=""

# === API SERVER ===
# Token wajib untuk akses endpoint /api/v1/*
API_BEARER_TOKEN="change-me"
API_HOST="0.0.0.0"
API_PORT=8000
# Pisahkan origin dengan koma. Gunakan "*" hanya untuk dev internal.
API_CORS_ORIGINS="*"

# Folder ingest upload (dipakai CLI ingest-uploads dan API upload endpoint)
UPLOADS_DIR="uploads"
